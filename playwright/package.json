{
  "name": "playwright-automation",
  "version": "1.0.0",
  "description": "Playwright automation framework using TypeScript.",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:chromium": "npx playwright test --project=chromium",
    "test:chromeHeaded": "npx playwright test --headed --project=chromium",
    "test:report": "npx playwright show-report",
    "allure:report": "npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "test:api": "npx playwright test --project=api"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/node": "^25.5.0",
    "allure-playwright": "^3.6.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "winston": "^3.19.0",
    "allure-commandline": "2.38.1"
  },
  "dependencies": {
    "winston": "^3.19.0"
  }
}