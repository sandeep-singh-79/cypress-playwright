{
  "name": "cypress-automation",
  "version": "1.0.0",
  "description": "Sample Cypress automation project.",
  "main": "index.js",
  "scripts": {
    "test": "npx cypress run",
    "open": "npx cypress open",
    "test:headed": "npx cypress open",
    "test:chrome": "npx cypress run --browser chrome",
    "test:spec": "npx cypress run --spec",
    "api:test": "cypress run --spec 'cypress/integration/*Api*.spec.js'",
    "allure:report": "npx allure generate allure-results --clean -o allure-report && npx allure open allure-report"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.38.1",
    "cypress": "^15.13.0"
  }
}
